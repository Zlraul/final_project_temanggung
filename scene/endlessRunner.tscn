script/source = "extends Parallax2D

@export var scroll_speed: Vector2 # variable untuk mengatur kecepatan scroll

func _ready():
	pass
	# untuk bagian lantai menggunakan tilemap layer dan juga parallax2d
	# dan juga autoscroll untuk memberikan ilusi bahwa karakter lah yang bergerak
	# namun yang bergerak adalah lantainya karakter tatap diam di tempat.

func _process(delta):
	scroll_offset.x += -Global.speed * delta
	# dalam setiap frame scroll_offsetnya ditambah sesuai dengan variable
	# scroll_speed dan dikalikan dengan delta agar speed tetap terjaga sama
	
"

