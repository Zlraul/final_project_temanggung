[sub_resource type="GDScript" id="GDScript_5xo84"]
script/source = "extends Node2D
@onready var timer: Timer = $Timer
var array := [
	preload(\"res://scene/jarum.tscn\"),
	preload(\"res://scene/jarum2.tscn\"),
	preload(\"res://scene/jarum3.tscn\"),
	preload(\"res://scene/jarum4.tscn\")
]

func _ready() -> void:
	pass
	


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass


func _on_timer_timeout() -> void:
	print(\"spawn stuff\")
	var jarum = array[randi_range(0,2)]
	var spawn = jarum.instantiate()
	add_child(spawn)
	rando()
	
	

func rando():
	var wait = randf_range(0.5,2.0)
	timer.start(wait)
	print(\"intervale : \", str(timer.wait_time))
	
	
"

