[sub_resource type="GDScript" id="GDScript_txmk2"]
script/source = "extends CharacterBody2D

@onready var animasi: AnimatedSprite2D = $AnimatedSprite2D

const SPEED = 300.0 * 45
const JUMP_VELOCITY = -400.0


func _physics_process(delta: float) -> void:
	# Add the gravity.
	if not is_on_floor():
		velocity += get_gravity() * delta
	elif is_on_floor():
		velocity.x = SPEED * delta
		animasi.play(\"berlari\")

	# Handle jump.
	if Input.is_action_just_pressed(\"lompat\") and is_on_floor():
		velocity.y = JUMP_VELOCITY
		animasi.play(\"melompat\")
	
	if velocity.y > 0.0 and not is_on_floor():
		animasi.play(\"jatuh\")
	
	#print(velocity.y)
#
	## Get the input direction and handle the movement/deceleration.
	## As good practice, you should replace UI actions with custom gameplay actions.
	#var direction := Input.get_axis(\"ui_left\", \"ui_right\")
	#if direction:
		#velocity.x = direction * SPEED
	#else:
		#velocity.x = move_toward(velocity.x, 0, SPEED)

	move_and_slide()

func is_player():
	pass
	
func _unhandled_input(event: InputEvent) -> void:
	if event:
		if Input.is_action_just_pressed(\"lompat\"):
			print(\"lompat pressed\")
		if Input.is_action_just_released(\"lompat\"):
			print(\"Lompat Released\")
"

